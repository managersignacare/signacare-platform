{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signacare.local/schemas/bug-closure-record.schema.json",
  "title": "Bug Closure Record Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generatedAt",
    "records"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    }
  },
  "$defs": {
    "approver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "name",
        "date"
      ],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 2
        },
        "name": {
          "type": "string",
          "minLength": 2
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "rolloutEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canaryEvidenceRef",
        "burnInEvidenceRef",
        "postBurnInEvidenceRef"
      ],
      "properties": {
        "canaryEvidenceRef": {
          "type": "string",
          "minLength": 3
        },
        "burnInEvidenceRef": {
          "type": "string",
          "minLength": 3
        },
        "postBurnInEvidenceRef": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bugId",
        "lane",
        "status",
        "fixCommitSha",
        "guards",
        "regressionTests",
        "evidenceArtifacts",
        "approvers",
        "lastValidatedAt"
      ],
      "properties": {
        "bugId": {
          "type": "string",
          "pattern": "^BUG-[A-Z0-9._-]+$"
        },
        "lane": {
          "type": "string",
          "minLength": 2
        },
        "status": {
          "type": "string",
          "enum": [
            "r0_ready",
            "r1_closure_pending",
            "closed"
          ]
        },
        "fixCommitSha": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,40}$"
        },
        "guards": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^guard:[a-z0-9:-]+$"
          }
        },
        "regressionTests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "evidenceArtifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "approvers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/approver"
          }
        },
        "lastValidatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "rolloutEvidence": {
          "$ref": "#/$defs/rolloutEvidence"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "closed"
              }
            }
          },
          "then": {
            "required": [
              "rolloutEvidence"
            ]
          }
        }
      ]
    }
  }
}
