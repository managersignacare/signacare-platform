# Signacare Web (Vite) env template
# Copy to apps/web/.env for local development.

VITE_API_URL=/api/v1
VITE_BUILD_SHA=dev
VITE_SCRIBE_LIVE_TRANSCRIPT=false
VITE_SCRIBE_LIVE_TRANSCRIPT_BATCH_MS=3000
VITE_SCRIBE_ASYNC_AMBIENT=true
VITE_SCRIBE_ASYNC_AMBIENT_MIN_SECONDS=180
# Synchronous AI summary/document requests. App Service may still require
# async job/polling for very long generations, but this prevents browser-side
# 30-second failures on ordinary summaries.
VITE_LONG_RUNNING_AI_TIMEOUT_MS=600000
