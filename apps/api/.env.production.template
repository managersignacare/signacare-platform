# Signacare EMR — Azure production environment template
#
# BUG-366a — copy to Azure App Service "Application Settings" (or to a
# .env.production file for VM/container deploys). Do NOT commit a
# populated copy.
#
# Every secret shown below with value "@Microsoft.KeyVault(SecretUri=...)"
# is resolved by Azure App Service at process start — your app just reads
# process.env.JWT_ACCESS_SECRET and the actual value comes from Key Vault
# via App Service's built-in reference syntax. Managed identity + RBAC
# role "Key Vault Secrets User" on the target vault is required.
#
# For keys that Signacare resolves itself (SECRETS_BACKEND=azure_keyvault),
# the resolver maps env var names to kebab-lower secret names:
#   JWT_ACCESS_SECRET       -> jwt-access-secret
#   DB_APP_PASSWORD         -> db-app-password
#   BLOB_AZURE_ACCOUNT_KEY    -> blob-azure-account-key
# See apps/api/src/config/secrets.ts:envKeyToVaultSecretName for the rule.

NODE_ENV=production
PORT=4000

# --- Secrets resolver -------------------------------------------------
# Two options for Azure — pick ONE (do NOT mix for the same key):
#
#   (a) Use App Service's @Microsoft.KeyVault(SecretUri=...) reference
#       syntax for every sensitive key. Azure materialises Key Vault
#       secrets into process.env BEFORE the Node process starts.
#       Leave SECRETS_BACKEND unset / =env. Only works on Azure App
#       Service (not on VMs, Container Apps without reference-syntax,
#       or AKS pods).
#
#   (b) Set SECRETS_BACKEND=azure_keyvault + AZURE_KEYVAULT_URL. The
#       app resolves each SENSITIVE_KEYS entry via the Azure Key Vault
#       REST API using managed identity at boot. Works on ANY Azure
#       host (App Service, VMs, Container Apps, AKS). Enables per-key
#       secret rotation without restarting via a separate restart.
#
# HYBRID MODE (discouraged but supported): if you pick option (b) but
# some keys already come from option (a)'s reference syntax, the
# resolver overwrites process.env only for keys where Key Vault has a
# matching secret name — reference-syntax values stay iff the resolver
# doesn't find a vault secret with that key's kebab-lower name.
#
# BUG-366a L4 requirement — when SECRETS_BACKEND=azure_keyvault, the
# following MUST resolve (via vault lookup or pre-existing env) or
# boot aborts: JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, DB_APP_PASSWORD,
# PHI_ENCRYPTION_KEY, BLIND_INDEX_KEY.
SECRETS_BACKEND=azure_keyvault
AZURE_KEYVAULT_URL=https://signacare-prod-kv.vault.azure.net

# --- PostgreSQL (Azure Database for PostgreSQL — Flexible Server) -----
# Staging SKU: Standard_D2s_v3 (2 vCore / 8 GiB / max_connections=859).
# Prod: scale to D4s_v3 or higher. See docs/plans/azure-staging-deployment.md §2.2.
DB_HOST=signacare-prod-pg.postgres.database.azure.com
DB_PORT=5432
DB_USER=signacare_owner
DB_PASSWORD=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/db-password/)
DB_NAME=signacaredb
DB_APP_USER=app_user
DB_APP_PASSWORD=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/db-app-password/)
# Azure PG Flexible Server requires TLS — the node-postgres bundle
# carries a matching CA chain. BUG-366b wires PGSSLMODE=require in db.ts.
DB_SSL=true
PGSSLMODE=require
# PgBouncer sidecar (transaction-mode) is recommended — if enabled,
# point DB_HOST at the PgBouncer endpoint on port 6432 instead.
# DB_HOST=signacare-prod-pg.postgres.database.azure.com
# DB_PORT=6432
# Pool sizing informed by Azure D2s_v3 max_connections=859 (~730 usable
# after Flexible Server reserves ~15% for superuser/autovacuum).
# BUG-366b defaults: 20 max / 2 min per worker when DB_PORT=6432 (PgBouncer).
# Connection-level timeouts are set automatically by db.ts afterCreate:
#   statement_timeout                    = 30s  (BUG-187)
#   idle_in_transaction_session_timeout  = 60s  (BUG-187)
#   lock_timeout                         =  5s  (BUG-187 follow-up)
# Also enforce at the Azure PG server-parameter level (portal) as defence
# in depth per docs/plans/azure-staging-deployment.md §2.2.
DB_POOL_MAX=20
DB_POOL_MIN=2

# --- JWT --------------------------------------------------------------
JWT_ACCESS_SECRET=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/jwt-access-secret/)
JWT_REFRESH_SECRET=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/jwt-refresh-secret/)
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# --- Azure Cache for Redis --------------------------------------------
# Port 6380 TLS-only; eviction policy MUST be noeviction (see
# docs/plans/azure-staging-deployment.md §2.3). Primary access key
# comes from Key Vault secret `redis-url`.
REDIS_URL=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/redis-url/)

# --- PHI + session + calendar secrets ---------------------------------
# Keep stable across deploys — rotating requires re-encryption.
PHI_ENCRYPTION_KEY=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/phi-encryption-key/)
BLIND_INDEX_KEY=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/blind-index-key/)
PATIENT_APP_DEDUPE_PEPPER=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/patient-app-dedupe-pepper/)
PATIENT_APP_DEDUPE_PEPPER_VERSION=v1
SESSION_SECRET=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/session-secret/)

# Release metadata (normally stamped by GitHub Actions / Azure deploy)
SIGNACARE_RELEASE_ENV=prod

# Staging-only prescriber test bypass. Leave false in production; the
# Azure deploy workflow sets this true only for the staging environment.
ALLOW_INVALID_HPII_IN_STAGING=false
CALENDAR_ICAL_SECRET=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/calendar-ical-secret/)
SIGNACARE_LICENSE_SECRET=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/signacare-license-secret/)

