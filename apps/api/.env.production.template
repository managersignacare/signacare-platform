# --- NASH mTLS (BUG-297) ---------------------------------------------
# HI Service SOAP calls require the NASH PKI certificate. The cert
# itself can live on Azure Files (mount to App Service) or in Key
# Vault as a certificate object — the passphrase is a regular secret.
HI_SERVICE_CERT_PATH=/home/site/secrets/nash-hi-service.p12
HI_SERVICE_CERT_PASSPHRASE=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/hi-service-cert-passphrase/)

# --- ADHA NPDS mTLS ---------------------------------------------------
ADHA_CERT_PATH=/home/site/secrets/adha.p12
ADHA_CERT_PASSPHRASE=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/adha-cert-passphrase/)
NPDS_API_URL=https://api.digitalhealth.gov.au/npds/v1
# NPDS_CONFORMANCE_ID is fallback-only. Canonical source is per-clinic DB column.
# NPDS_CONFORMANCE_ID=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/npds-conformance-id/)
NPDS_PAYLOAD_SECURITY_MODE=off
# NPDS_PAYLOAD_SIGNING_PRIVATE_KEY_PEM=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/npds-payload-signing-private-key-pem/)
# NPDS_PAYLOAD_SIGNING_KEY_ID=npds-key-2026-q2
# NPDS_PAYLOAD_ENCRYPTION_KEY_HEX=@Microsoft.KeyVault(SecretUri=https://signacare-prod-kv.vault.azure.net/secrets/npds-payload-encryption-key-hex/)
# NPDS_SUBMIT_MAX_ATTEMPTS=3
# NPDS_SUBMIT_RETRY_BASE_MS=250
# NPDS_SUBMIT_RETRY_MAX_MS=2000
# STRICT_NPDS_CONFORMANCE=false
# STRICT_NPDS_PAYLOAD_SECURITY=false

# --- TLS (cert termination) ------------------------------------------
# When hosted on Azure App Service behind Front Door / App Gateway,
# TLS terminates at the edge and the Node process does NOT present
# its own cert. Leave TLS_CERT_PATH / TLS_KEY_PATH unset.
# TLS_CERT_PATH=
# TLS_KEY_PATH=

