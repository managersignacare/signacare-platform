# Scheduling / housekeeping
# AUDIO_RETENTION_DAYS=90
# AUDIO_RETENTION_CRON=0 3 * * *
# AUDIO_RETENTION_TZ=Australia/Melbourne
# MATVIEW_REFRESH_CRON=0 2 * * *
# MATVIEW_REFRESH_TZ=Australia/Melbourne
# MATVIEW_REFRESH_VIEWS=dashboard_counts_mv

# Secrets resolver backends (non-Azure local variants)
# SECRETS_FILE_PATH=/etc/signacare/secrets.json
# SECRETS_JSON={"JWT_ACCESS_SECRET":"..."}

# FCM / ACS channels (required in production by boot checks)
# FCM_SERVICE_ACCOUNT_PATH=/secure/firebase-service-account.json
# ACS_CONNECTION_STRING=endpoint=https://...
# ACS_FROM_PHONE=+61123456789

