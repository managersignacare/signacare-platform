# ACCESS_TOKEN_SECRET=CHANGE_ME_64_CHAR_HEX
# JWT_SECRET=CHANGE_ME_64_CHAR_HEX
# AUTH_RATE_LIMIT=120
# API_RATE_LIMIT=500
# PATIENT_AUTH_RATE_LIMIT=60
# PATIENT_LOGIN_PHONE_RATE_LIMIT=10
# PATIENT_ACTIVATE_CODE_RATE_LIMIT=8
# BREAK_GLASS_TTL_MINUTES=30
# STEP_UP_TTL_MINUTES=15
# SESSION_IDLE_MINUTES=30
# SUPERADMIN_ALLOWED_EMAIL_DOMAINS=signacare.net,signacare.local

# Observability / audit / runtime
# LOG_LEVEL=info
# LOGIN_PINO_TIMING=true
# LOGIN_AUDIT_TIMEOUT_MS=250
# AUTH_CHAIN_PINO_TIMING=true
# AUTH_CHAIN_STAGE_TIMEOUT_MS=250
# SENTRY_DSN=https://key@org.ingest.sentry.io/id
# SLACK_WEBHOOK_SECURITY=https://hooks.slack.com/services/XXX/YYY/ZZZ
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=signacare-api
# OTEL_SERVICE_VERSION=1.0.0

# Redis / workers / SSE
# WORKERS=all
# SSE_MAX_CONNECTIONS=500
# SSE_IDLE_TIMEOUT_MS=300000

# Storage / uploads / antivirus
# UPLOAD_BASE_DIR=/var/signacare/uploads
# UPLOAD_RATE_LIMIT=100
# ANTIVIRUS_SCAN_CMD=clamscan --no-summary
# REFERRAL_UPLOAD_ANTIVIRUS_MODE=required
# BLOB_STORAGE_BACKEND=local
# BLOB_AZURE_ACCOUNT_NAME=signacaredevstorage
# BLOB_AZURE_ACCOUNT_KEY=CHANGE_ME
# BLOB_AZURE_CONTAINER=attachments
# BLOB_AZURE_ENDPOINT=https://signacaredevstorage.blob.core.windows.net
# BLOB_S3_BUCKET=signacare-dev
# BLOB_S3_REGION=ap-southeast-2
# BLOB_S3_ENDPOINT=https://s3.ap-southeast-2.amazonaws.com
# BLOB_S3_FORCE_PATH_STYLE=false
# BLOB_S3_ACCESS_KEY_ID=CHANGE_ME
# BLOB_S3_SECRET_ACCESS_KEY=CHANGE_ME

# Replica / pooling / proxy
# DB_POOL_MIN=5
# DB_REPLICA_HOST=localhost
# DB_REPLICA_PORT=5433
# DB_REPLICA_POOL_MAX=30
# DB_REPLICA_REQUIRED=false
# DB_SSL_REJECT_UNAUTHORIZED=true
# PGBOUNCER_HOST=
# TRUST_PROXY=1

# Pool budget worksheet contract (capacity guard + startup assertion)
# Set these explicitly per environment before production rollout.
API_PROCESS_COUNT=4
DB_POOL_BUDGET_ASSERT_MODE=warn
DB_USABLE_BACKEND_CONNECTIONS=730
DB_RESERVED_BACKEND_CONNECTIONS=146
DB_NON_API_CONSUMERS=10
DB_SAFE_UTILIZATION_CEILING=0.70

# Optional boot context / local utilities
# CLINIC_ID=00000000-0000-0000-0000-000000000000
# TEST_DEFAULT_CLINIC_ID=11111111-1111-1111-1111-111111111111
# SIGNACARE_HOME=/opt/signacare
# SIGNACARE_TEST_RATE_LIMIT_MODE=off
# ALLOW_DEMO_SEED=0
# DEMO_SEED=
# DEMO_WIPE=0
# TZ=Australia/Melbourne
# BACKUP_TZ=Australia/Melbourne
# HF_SERVER_URL=http://localhost:4000
# CDN_HOSTS=cdn.example.com
# API_KEYS=key1,key2
# ZITAVI_GATEWAY_URL=http://localhost:4002
# ZITAVI_API_KEY=CHANGE_ME
# PRIVACY_OFFICER_EMAIL=privacy@example.com

# Feature controls / classifiers
# AI_CHAT_CLASSIFIER_MODEL=qwen2.5:14b
# LLM_MAX_CONCURRENT=2
# WHISPER_MODEL=base
# WHISPER_MAX_CONCURRENT=2
# EVIDENCE_BACKEND=stub
# OCR_PROVIDER=tesseract
