{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/src/index.js",
  "scripts": {
    "dev:preflight": "node scripts/ensure-port-available.mjs",
    "dev": "npm run dev:preflight && tsx watch --clear-screen=false -r dotenv/config -r tsconfig-paths/register src/index.ts",
    "dev:legacy": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json src/index.ts",
    "build": "npm --prefix ../../packages/shared run build && rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:check": "tsc --noEmit -p tsconfig.json",
    "build:check:watch": "tsc --noEmit --watch -p tsconfig.json",
    "start": "node -r dotenv/config dist/src/index.js",
    "migrate": "node -r dotenv/config dist/scripts/migrate.js",
    "migrate:dev": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json scripts/migrate.ts",
    "migrate:rehearsal": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json scripts/migration-rehearsal.ts",
    "db:snapshot": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json scripts/generate-schema-snapshot.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "probe:integration-reruns": "node scripts/run-integration-reruns.mjs",
    "probe:ollama-log-hygiene": "node scripts/verify-ollama-log-hygiene.mjs",
    "test:integration:live": "vitest run --config vitest.live.config.ts",
    "lint": "eslint src --ext .ts",
    "seed:canonical-personas": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json tests/fixtures/canonical-personas.ts",
    "seed:good-health": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json src/seed-good-health/index.ts",
    "seed:rating-scales": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json src/seed-rating-scales.ts",
    "seed:e2e-fixtures": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json src/seed-e2e-fixtures.ts",
    "seed:demo-patient-registrations": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json scripts/seed-demo-patient-registrations.ts",
    "seed:demo-patient-messages-and-tasks": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json scripts/seed-demo-patient-messages-and-tasks.ts",
    "seed:diverse-appointments": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json scripts/seed-future-appointments-and-reviews.ts",
    "seed:noah-bennett-longitudinal-demo": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json scripts/seed-noah-bennett-longitudinal-demo.ts",
    "seed:psychiatric-longitudinal-demos": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json scripts/seed-psychiatric-longitudinal-demos.ts",
    "seed:comprehensive-operational-demo": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json scripts/seed-comprehensive-operational-demo.ts",
    "cleanup:single-demo-org": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.node.json scripts/cleanup-single-demo-org.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.654.0",
    "@aws-sdk/s3-request-presigner": "^3.654.0",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.11.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.49.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.1",
    "@opentelemetry/resources": "^1.26.0",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "@sentry/node": "^10.45.0",
    "@signacare/shared": "1.0.0",
    "@simplewebauthn/server": "^13.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/uuid": "^10.0.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^4.17.0",
    "bwip-js": "^4.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "ical-generator": "7.2.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "pg": "^8.11.0",
    "pino": "^8.21.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "redis": "^4.6.0",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@types/speakeasy": "^2.0.10",
    "dotenv-cli": "^11.0.0",
    "nock": "^14.0.13",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
