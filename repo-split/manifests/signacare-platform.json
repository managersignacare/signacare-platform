{
  "version": 1,
  "repoName": "signacare-platform",
  "description": "Primary platform repo for web, API, contracts, migrations, IaC, deployment, and operational documentation.",
  "authoritativeSource": "original-monorepo",
  "repoScaffoldPath": "repo-split/scaffolds/signacare-platform",
  "ownership": {
    "include": [
      ".claude/",
      ".github/",
      ".husky/",
      "apps/api/",
      "apps/emr-gateway/",
      "apps/web/",
      "deploy/",
      "docs/",
      "e2e/",
      "eslint-plugins/",
      "infra/",
      "installer/",
      "models/",
      "packages/",
      "repo-split/",
      "scripts/",
      "standalone/",
      "tests/",
      ".dependency-cruiser.cjs",
      ".dockerignore",
      ".env.example",
      ".env.production",
      ".eslintrc.cjs",
      ".gitleaks.toml",
      ".gitignore",
      ".prettierrc",
      "CLAUDE.md",
      "README.md",
      "docker-compose.yml",
      "ecosystem.config.js",
      "knip.json",
      "package-lock.json",
      "package.json",
      "playwright.config.ts",
      "stryker.conf.mjs",
      "tsconfig.base.json",
      "tsconfig.json",
      "vitest.config.ts"
    ],
    "exclude": [
      "apps/mobile/",
      "apps/patient-app/",
      "artifacts/",
      "audit-reports/",
      "backups/",
      "node_modules/",
      "test-results/"
    ]
  }
}
