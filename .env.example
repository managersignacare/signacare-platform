# Signacare monorepo root env template
#
# Root workspace scripts usually read per-app env files instead:
# - API: apps/api/.env.example
# - EMR Gateway: apps/emr-gateway/.env.example
# - Web: apps/web/.env.example
#
# Keep this file non-empty so repo-hygiene guards can detect accidental
# zero-byte templates and stale artifacts.

# Workspace defaults (non-secret)
NODE_ENV=development
PORT=4000
