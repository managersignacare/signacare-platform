# -----------------------------------------------------------------------------
# Signacare EMR - Windows VM environment template (D:\Signacare\app\api\.env)
#
# Copy to D:\Signacare\app\api\.env on the VM and fill the secret values.
# This template is for the Windows-VM dev/test deployment; production
# values should pull from Azure Key Vault (see SECRETS_BACKEND below).
# -----------------------------------------------------------------------------

NODE_ENV=production
PORT=4000

# -- PostgreSQL (co-hosted on the same VM at 127.0.0.1:5432) ----------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=signacaredb
DB_USER=signacare_owner
DB_PASSWORD=<from-keyvault-or-02-create-database-output>
DB_APP_USER=app_user
DB_APP_PASSWORD=<from-keyvault-or-02-create-database-output>
DB_SSL=false   # local socket - TLS not required since traffic never leaves the VM

# -- Redis (Memurai, co-hosted at 127.0.0.1:6379) ----------------------------
REDIS_URL=redis://127.0.0.1:6379

# -- App secrets - generate with `openssl rand -hex 32` (or PowerShell equivalent) -
# CRITICAL: PHI_ENCRYPTION_KEY must NEVER rotate after first deploy with PHI.
JWT_ACCESS_SECRET=<generate-32-byte-hex>
JWT_REFRESH_SECRET=<generate-32-byte-hex>
PHI_ENCRYPTION_KEY=<generate-32-byte-hex-keep-forever>
BLIND_INDEX_KEY=<generate-32-byte-hex>
SESSION_SECRET=<generate-32-byte-hex>

# Session idle timeout - production value 15 minutes per BUG-P2 + DH-3869
SESSION_IDLE_TIMEOUT=900

# -- File storage - local NTFS path on data drive ----------------------------
UPLOAD_BASE_DIR=D:\Signacare\uploads
LOG_DIR=D:\Signacare\logs

# -- Australian time + retention defaults ------------------------------------
RETENTION_DRY_RUN=true
RETENTION_TZ=Australia/Sydney

# -- Integrations (disabled in dev/test until vendor sandbox certs land) -----
HL7_LAB_PROTOCOL=disabled
ERX_ADAPTER=disabled
SAFESCRIPT_ENABLED=false

# -- CORS - set to the public FQDN of the VM --------------------------------
# Find the FQDN with: az network public-ip show --resource-group signacare-windows-dev-rg --name signacare-pip-dev --query dnsSettings.fqdn
CORS_ORIGIN=https://signacare-dev.australiaeast.cloudapp.azure.com

# -- WebAuthn (FIDO2) - set to bare hostname, no protocol --------------------
WEBAUTHN_RP_ID=signacare-dev.australiaeast.cloudapp.azure.com
WEBAUTHN_RP_NAME=Signacare EMR (Dev)

# -- Secrets backend ---------------------------------------------------------
# For dev/test: use 'env' so the values above are read directly.
# For prod: set to 'azure_keyvault' and provide AZURE_KEYVAULT_URL.
SECRETS_BACKEND=env
# AZURE_KEYVAULT_URL=https://<your-kv>.vault.azure.net

# -- LLM / scribe (optional; disable for first-deploy) ------------------------
LLM_ENABLED=false
WHISPER_ENABLED=false
ALLOW_MISSING_PGVECTOR=true

# -- Observability -----------------------------------------------------------
LOG_LEVEL=info
# Set to 'debug' temporarily during initial deploy troubleshooting.
